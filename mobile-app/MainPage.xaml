<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AquariumController.Mobile.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:behaviors="clr-namespace:AquariumController.Mobile.Behaviors"
    xmlns:services="clr-namespace:AquariumController.Mobile.Services"
    xmlns:viewModels="clr-namespace:AquariumController.Mobile.ViewModels"
    x:DataType="viewModels:MainViewModel"
    BackgroundColor="Transparent"
    NavigationPage.HasNavigationBar="False"
    Title="Akwarium">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0A1E3A" Offset="0.0" />
            <GradientStop Color="#061830" Offset="0.3" />
            <GradientStop Color="#041020" Offset="0.6" />
            <GradientStop Color="#020814" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ContentPage.Resources>
        <Color x:Key="SidebarBg">#B6080C1C</Color>
        <Color x:Key="SidebarNavActive">#7A0C2132</Color>
        <Color x:Key="MainSurface">#6C081120</Color>
        <Color x:Key="PanelBg">#700B1424</Color>
        <Color x:Key="CardBg">#5C0D182B</Color>
        <Color x:Key="BorderColor">#72324761</Color>
        <Color x:Key="BorderAccent">#184C62</Color>
        <Color x:Key="TextPrimary">#F1F5F9</Color>
        <Color x:Key="TextSecondary">#94A3B8</Color>
        <Color x:Key="TextMuted">#475569</Color>
        <Color x:Key="AccentCyan">#22D3EE</Color>
        <Color x:Key="AccentYellow">#FBBF24</Color>
        <Color x:Key="AccentBlue">#60A5FA</Color>
        <Color x:Key="AccentPink">#F472B6</Color>
        <Color x:Key="AccentGreen">#34D399</Color>
        <Color x:Key="AccentOrange">#FB923C</Color>
        <Color x:Key="AccentPurple">#A78BFA</Color>
        <Color x:Key="AccentRed">#F87171</Color>
        <Color x:Key="GhostButtonBg">#0E192B</Color>
        <Color x:Key="TerminalBg">#09111E</Color>

        <Style x:Key="FluentButtonStyle" TargetType="Button">
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="HeightRequest" Value="46" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontFamily" Value="OpenSansSemibold" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="Scale" Value="1.03" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Scale" Value="0.97" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="HeightRequest" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontFamily" Value="OpenSansSemibold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="Scale" Value="1.03" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Scale" Value="0.96" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="CornerRadius" Value="72" />
            <Setter Property="HeightRequest" Value="144" />
            <Setter Property="WidthRequest" Value="144" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="OpenSansSemibold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="Scale" Value="1.08" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Scale" Value="0.92" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{StaticResource PanelBg}" />
            <Setter Property="Stroke" Value="{StaticResource BorderColor}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeShape" Value="RoundRectangle 22" />
        </Style>

        <Style x:Key="SubCardStyle" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{StaticResource CardBg}" />
            <Setter Property="Stroke" Value="{StaticResource BorderColor}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeShape" Value="RoundRectangle 18" />
        </Style>

        <Style x:Key="PageTitleStyle" TargetType="Label">
            <Setter Property="FontFamily" Value="OpenSansSemibold" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        </Style>

        <Style x:Key="PageSubtitleStyle" TargetType="Label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="Label">
            <Setter Property="FontFamily" Value="OpenSansSemibold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="Label">
            <Setter Property="FontFamily" Value="OpenSansSemibold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="Label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        </Style>

        <Style x:Key="TinyMutedTextStyle" TargetType="Label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="Label">
            <Setter Property="FontFamily" Value="OpenSansSemibold" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        </Style>
    </ContentPage.Resources>

    <Grid>
        <!-- Dark overlay for readability -->
        <BoxView BackgroundColor="#020814" Opacity="0.85" />

        <Grid Padding="22" ColumnDefinitions="240,*" ColumnSpacing="22">
        <Border Grid.Column="0" BackgroundColor="{StaticResource SidebarBg}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 26" StrokeThickness="1">
            <Grid RowDefinitions="Auto,*,Auto">
                <Grid Padding="20,20,20,18" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Border WidthRequest="42" HeightRequest="42" BackgroundColor="{StaticResource AccentCyan}" StrokeShape="RoundRectangle 12">
                        <Label HorizontalOptions="Center" VerticalOptions="Center" FontFamily="Segoe Fluent Icons" FontSize="24" Text="&#xE90F;" TextColor="White" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label FontFamily="OpenSansSemibold" FontSize="16" Text="Sterownik Akwarium" TextColor="{StaticResource TextPrimary}" />
                        <Label FontSize="12" Text="PRO" TextColor="{StaticResource AccentCyan}" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Grid.Row="1" Padding="12,8,12,12" Spacing="8">
                    <Label Margin="12,0,0,4" FontFamily="OpenSansSemibold" FontSize="10" Text="MENU" TextColor="{StaticResource TextMuted}" />

                    <Border Padding="12,10" BackgroundColor="Transparent" Stroke="Transparent" StrokeShape="RoundRectangle 18" StrokeThickness="1">
                        <Border.Triggers>
                            <DataTrigger Binding="{Binding IsDashboardTabSelected}" TargetType="Border" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource SidebarNavActive}" />
                                <Setter Property="Stroke" Value="{StaticResource BorderAccent}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShowDashboardTabCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border WidthRequest="30" HeightRequest="30" BackgroundColor="#0F2732" Stroke="Transparent" StrokeShape="RoundRectangle 10">
                                <Label HorizontalOptions="Center" VerticalOptions="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE80F;" TextColor="White" />
                            </Border>
                            <Label Grid.Column="1" VerticalOptions="Center" FontSize="13" Text="Panel glowny" TextColor="{StaticResource TextPrimary}" />
                        </Grid>
                    </Border>

                    <Border Padding="12,10" BackgroundColor="Transparent" Stroke="Transparent" StrokeShape="RoundRectangle 18" StrokeThickness="1">
                        <Border.Triggers>
                            <DataTrigger Binding="{Binding IsScheduleTabSelected}" TargetType="Border" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource SidebarNavActive}" />
                                <Setter Property="Stroke" Value="{StaticResource BorderAccent}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShowScheduleTabCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border WidthRequest="30" HeightRequest="30" BackgroundColor="#221E0E" Stroke="Transparent" StrokeShape="RoundRectangle 10">
                                <Label HorizontalOptions="Center" VerticalOptions="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE81C;" TextColor="White" />
                            </Border>
                            <Label Grid.Column="1" VerticalOptions="Center" FontSize="13" Text="Harmonogram" TextColor="{StaticResource TextPrimary}" />
                        </Grid>
                    </Border>

                    <Border Padding="12,10" BackgroundColor="Transparent" Stroke="Transparent" StrokeShape="RoundRectangle 18" StrokeThickness="1">
                        <Border.Triggers>
                            <DataTrigger Binding="{Binding IsFeederTabSelected}" TargetType="Border" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource SidebarNavActive}" />
                                <Setter Property="Stroke" Value="{StaticResource BorderAccent}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShowFeederTabCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border WidthRequest="30" HeightRequest="30" BackgroundColor="#251224" Stroke="Transparent" StrokeShape="RoundRectangle 10">
                                <Label HorizontalOptions="Center" VerticalOptions="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE8F3;" TextColor="White" />
                            </Border>
                            <Label Grid.Column="1" VerticalOptions="Center" FontSize="13" Text="Karmnik" TextColor="{StaticResource TextPrimary}" />
                        </Grid>
                    </Border>

                    <Border Padding="12,10" BackgroundColor="Transparent" Stroke="Transparent" StrokeShape="RoundRectangle 18" StrokeThickness="1">
                        <Border.Triggers>
                            <DataTrigger Binding="{Binding IsLogsTabSelected}" TargetType="Border" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource SidebarNavActive}" />
                                <Setter Property="Stroke" Value="{StaticResource BorderAccent}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShowLogsTabCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border WidthRequest="30" HeightRequest="30" BackgroundColor="#111926" Stroke="Transparent" StrokeShape="RoundRectangle 10">
                                <Label HorizontalOptions="Center" VerticalOptions="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE8FD;" TextColor="White" />
                            </Border>
                            <Label Grid.Column="1" VerticalOptions="Center" FontSize="13" Text="Logi systemowe" TextColor="{StaticResource TextPrimary}" />
                        </Grid>
                    </Border>

                    <Border Padding="12,10" BackgroundColor="Transparent" Stroke="Transparent" StrokeShape="RoundRectangle 18" StrokeThickness="1">
                        <Border.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsTabSelected}" TargetType="Border" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource SidebarNavActive}" />
                                <Setter Property="Stroke" Value="{StaticResource BorderAccent}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShowSettingsTabCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border WidthRequest="30" HeightRequest="30" BackgroundColor="#17122A" Stroke="Transparent" StrokeShape="RoundRectangle 10">
                                <Label HorizontalOptions="Center" VerticalOptions="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE713;" TextColor="White" />
                            </Border>
                            <Label Grid.Column="1" VerticalOptions="Center" FontSize="13" Text="Ustawienia" TextColor="{StaticResource TextPrimary}" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <Border Grid.Row="2" Margin="14,0,14,14" Padding="14" BackgroundColor="#0A1323" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 18" StrokeThickness="1">
                    <VerticalStackLayout Spacing="10">
                        <HorizontalStackLayout Spacing="8">
                            <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4">
                                <BoxView.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" TargetType="BoxView" Value="True">
                                        <Setter Property="Color" Value="{StaticResource AccentGreen}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsConnected}" TargetType="BoxView" Value="False">
                                        <Setter Property="Color" Value="{StaticResource AccentRed}" />
                                    </DataTrigger>
                                </BoxView.Triggers>
                            </BoxView>
                            <Label FontFamily="OpenSansSemibold" FontSize="12" Text="{Binding ConnectionStatusBadgeText}" TextColor="{StaticResource TextPrimary}" />
                        </HorizontalStackLayout>
                        <Label FontSize="11" LineBreakMode="TailTruncation" Text="{Binding SelectedDeviceSummary}" TextColor="{StaticResource TextSecondary}" />
                        <Label FontSize="11" LineBreakMode="TailTruncation" Text="{Binding NetworkSummaryText}" TextColor="{StaticResource TextSecondary}" />
                        <Label FontSize="10" Text="{Binding CurrentFirmwareVersionText}" TextColor="{StaticResource TextMuted}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1" BackgroundColor="{StaticResource MainSurface}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 30" StrokeThickness="1">
            <Grid>
                <ScrollView IsVisible="{Binding IsDashboardTabSelected}">
                    <ScrollView.Behaviors>
                        <behaviors:EntranceAnimationBehavior />
                    </ScrollView.Behaviors>
                    <VerticalStackLayout Padding="30" Spacing="20">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                            <VerticalStackLayout Spacing="4">
                                <Label Style="{StaticResource PageTitleStyle}" Text="Panel glowny" />
                                <Label Style="{StaticResource PageSubtitleStyle}" Text="{Binding CurrentDateText}" />
                            </VerticalStackLayout>
                            <HorizontalStackLayout Grid.Column="1" Spacing="10">
                                <Border Padding="14,10" BackgroundColor="#0D182B" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 16">
                                    <VerticalStackLayout Spacing="2">
                                        <Label FontFamily="OpenSansSemibold" FontSize="18" HorizontalTextAlignment="End" Text="{Binding CurrentTimeText}" TextColor="{StaticResource AccentCyan}" />
                                        <Label FontSize="11" HorizontalTextAlignment="End" Text="{Binding ConnectionStatusBadgeText}" TextColor="{StaticResource TextSecondary}" />
                                    </VerticalStackLayout>
                                </Border>
                            </HorizontalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                            <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}"><VerticalStackLayout Padding="16" Spacing="6"><Label Style="{StaticResource TinyMutedTextStyle}" Text="TEMPERATURA" /><Label Style="{StaticResource MetricValueStyle}" Text="{Binding CurrentStatus.TemperatureText}" /><Label Style="{StaticResource MutedTextStyle}" Text="{Binding TemperatureSummaryText}" /></VerticalStackLayout></Border>
                            <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}"><VerticalStackLayout Padding="16" Spacing="6"><Label Style="{StaticResource TinyMutedTextStyle}" Text="BATERIA" /><Label Style="{StaticResource MetricValueStyle}" Text="{Binding CurrentStatus.BatteryPercent, StringFormat='{}{0}%'}" /><ProgressBar BackgroundColor="#16263B" HeightRequest="10" Progress="{Binding BatteryProgress}" ProgressColor="{Binding BatteryFillColor}" /></VerticalStackLayout></Border>
                            <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}"><VerticalStackLayout Padding="16" Spacing="6"><Label Style="{StaticResource TinyMutedTextStyle}" Text="SIEC" /><Label Style="{StaticResource MetricValueStyle}" FontSize="22" Text="{Binding ConnectionStatusBadgeText}" /><Label Style="{StaticResource MutedTextStyle}" Text="{Binding NetworkSummaryText}" /></VerticalStackLayout></Border>
                        </Grid>

                        <Grid ColumnDefinitions="1.1*,1*,0.8*" ColumnSpacing="14">
                            <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}">
                                <VerticalStackLayout Padding="18" Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto"><Label Style="{StaticResource SectionTitleStyle}" Text="Przekazniki" /><Border Grid.Column="1" Padding="10,4" BackgroundColor="#1B2437" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12"><Label FontFamily="OpenSansSemibold" FontSize="11" Text="{Binding RelayActiveCount, StringFormat='{}{0} / 4 aktywnych'}" TextColor="{StaticResource TextSecondary}" /></Border></Grid>
                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                                        <Border Style="{StaticResource SubCardStyle}" BackgroundColor="#142333" Stroke="#4A4320">
                                            <VerticalStackLayout Padding="12" Spacing="8">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                    <Border WidthRequest="34" HeightRequest="34" BackgroundColor="#363012" Stroke="Transparent" StrokeShape="RoundRectangle 10"><Label HorizontalOptions="Center" VerticalOptions="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE793;" TextColor="{StaticResource AccentYellow}" /></Border>
                                                    <Label Grid.Column="1" HorizontalOptions="End" BackgroundColor="#152234" Padding="10,2" FontFamily="OpenSansSemibold" FontSize="11" Text="{Binding CurrentStatus.LightText}" TextColor="{StaticResource TextPrimary}" />
                                                </Grid>
                                                <Label FontFamily="OpenSansSemibold" FontSize="13" Text="Swiatlo" TextColor="{StaticResource TextPrimary}" />
                                                <Label FontSize="11" Text="Wyl. harmonogram" TextColor="{StaticResource TextSecondary}" />
                                            </VerticalStackLayout>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource SubCardStyle}" BackgroundColor="#10293A" Stroke="#1A5E78">
                                            <VerticalStackLayout Padding="12" Spacing="8">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                    <Border WidthRequest="34" HeightRequest="34" BackgroundColor="#0B3A4E" Stroke="Transparent" StrokeShape="RoundRectangle 10"><Label HorizontalOptions="Center" VerticalOptions="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE71C;" TextColor="{StaticResource AccentCyan}" /></Border>
                                                    <Label Grid.Column="1" HorizontalOptions="End" BackgroundColor="#0B3A4E" Padding="10,2" FontFamily="OpenSansSemibold" FontSize="11" Text="{Binding CurrentStatus.FilterText}" TextColor="{StaticResource AccentCyan}" />
                                                </Grid>
                                                <Label FontFamily="OpenSansSemibold" FontSize="13" Text="Filtr" TextColor="{StaticResource TextPrimary}" />
                                                <Label FontSize="11" Text="{Binding FilterScheduleSummaryText}" TextColor="{StaticResource AccentCyan}" />
                                            </VerticalStackLayout>
                                        </Border>
                                        <Border Grid.Row="1" Style="{StaticResource SubCardStyle}" BackgroundColor="#2A1D12" Stroke="#6B421C">
                                            <VerticalStackLayout Padding="12" Spacing="8">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                    <Border WidthRequest="34" HeightRequest="34" BackgroundColor="#3A2716" Stroke="Transparent" StrokeShape="RoundRectangle 10"><Label HorizontalOptions="Center" VerticalOptions="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE9CA;" TextColor="{StaticResource AccentOrange}" /></Border>
                                                    <Label Grid.Column="1" HorizontalOptions="End" BackgroundColor="#352514" Padding="10,2" FontFamily="OpenSansSemibold" FontSize="11" Text="{Binding CurrentStatus.HeaterText}" TextColor="{StaticResource AccentOrange}" />
                                                </Grid>
                                                <Label FontFamily="OpenSansSemibold" FontSize="13" Text="Grzalka" TextColor="{StaticResource TextPrimary}" />
                                                <Label FontSize="11" Text="Temp. OK - czeka" TextColor="{StaticResource TextSecondary}" />
                                            </VerticalStackLayout>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SubCardStyle}" BackgroundColor="#112E2C" Stroke="#177568">
                                            <VerticalStackLayout Padding="12" Spacing="8">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                    <Border WidthRequest="34" HeightRequest="34" BackgroundColor="#0C3A36" Stroke="Transparent" StrokeShape="RoundRectangle 10"><Label HorizontalOptions="Center" VerticalOptions="Center" FontFamily="Segoe Fluent Icons" FontSize="16" Text="&#xE753;" TextColor="{StaticResource AccentGreen}" /></Border>
                                                    <Label Grid.Column="1" HorizontalOptions="End" BackgroundColor="#0D3C3A" Padding="10,2" FontFamily="OpenSansSemibold" FontSize="11" Text="{Binding ServoModeText}" TextColor="{StaticResource AccentGreen}" />
                                                </Grid>
                                                <Label FontFamily="OpenSansSemibold" FontSize="13" Text="Napowietrzanie" TextColor="{StaticResource TextPrimary}" />
                                                <Label FontSize="11" Text="{Binding AerationScheduleSummaryText}" TextColor="{StaticResource AccentGreen}" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}">
                                <VerticalStackLayout Padding="18" Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto"><Label Style="{StaticResource SectionTitleStyle}" Text="Harmonogram dzisiaj" /><Button Grid.Column="1" BackgroundColor="{StaticResource GhostButtonBg}" BorderColor="{StaticResource BorderColor}" BorderWidth="1" Command="{Binding ShowScheduleTabCommand}" CornerRadius="14" HeightRequest="38" Padding="14,0" Text="Edytuj" TextColor="{StaticResource AccentCyan}" /></Grid>
                                    <Border Style="{StaticResource SubCardStyle}"><Grid Padding="12" ColumnDefinitions="*,Auto"><Label FontSize="12" Text="Swiatlo" TextColor="{StaticResource TextPrimary}" /><Label Grid.Column="1" FontSize="12" Text="{Binding LightScheduleSummaryText}" TextColor="{StaticResource TextSecondary}" /></Grid></Border>
                                    <Border Style="{StaticResource SubCardStyle}"><Grid Padding="12" ColumnDefinitions="*,Auto"><Label FontSize="12" Text="Filtr" TextColor="{StaticResource TextPrimary}" /><Label Grid.Column="1" FontSize="12" Text="{Binding FilterScheduleSummaryText}" TextColor="{StaticResource TextSecondary}" /></Grid></Border>
                                    <Border Style="{StaticResource SubCardStyle}"><Grid Padding="12" ColumnDefinitions="*,Auto"><Label FontSize="12" Text="Napowietrzanie" TextColor="{StaticResource TextPrimary}" /><Label Grid.Column="1" FontSize="12" Text="{Binding AerationScheduleSummaryText}" TextColor="{StaticResource TextSecondary}" /></Grid></Border>
                                    <Border Style="{StaticResource SubCardStyle}"><Grid Padding="12" ColumnDefinitions="*,Auto"><Label FontSize="12" Text="Karmienie" TextColor="{StaticResource TextPrimary}" /><Label Grid.Column="1" FontSize="12" Text="{Binding FeedScheduleSummaryText}" TextColor="{StaticResource TextSecondary}" /></Grid></Border>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}">
                                <VerticalStackLayout Padding="18" HorizontalOptions="Center" Spacing="12">
                                    <Label Style="{StaticResource SectionTitleStyle}" Text="Karmnik" />
                                    <Border WidthRequest="138" HeightRequest="138" Padding="14" BackgroundColor="#1C1120" Stroke="#8B2E67" StrokeShape="RoundRectangle 69" StrokeThickness="2">
                                        <Grid>
                                            <Button HorizontalOptions="Center" VerticalOptions="Center" BackgroundColor="#32142D" Command="{Binding FeedNowCommand}" CornerRadius="52" HeightRequest="104" Padding="0" Text="Karm teraz" TextColor="{StaticResource AccentPink}" WidthRequest="104" />
                                        </Grid>
                                    </Border>
                                    <Label FontSize="12" HorizontalTextAlignment="Center" Text="{Binding FeedScheduleSummaryText}" TextColor="{StaticResource TextSecondary}" />
                                    <Button BackgroundColor="{StaticResource GhostButtonBg}" BorderColor="{StaticResource BorderColor}" BorderWidth="1" Command="{Binding ShowFeederTabCommand}" Style="{StaticResource SecondaryButtonStyle}" Text="Zarzadzaj" TextColor="{StaticResource TextPrimary}" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*" ColumnSpacing="14">
                            <Border Style="{StaticResource PanelCardStyle}">
                                <VerticalStackLayout Padding="18" Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Style="{StaticResource SectionTitleStyle}" Text="Zakres temperatury" />
                                        <Border Grid.Column="1" Padding="10,4" BackgroundColor="#13243A" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12"><Label FontSize="12" Text="Ostatnie 3 godz. (20 odczytow)" TextColor="{StaticResource TextSecondary}" /></Border>
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="#1B3A5B" />
                                    <Grid ColumnDefinitions="*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*" ColumnSpacing="4" HeightRequest="88" VerticalOptions="End">
                                        <Border Grid.Column="0" HeightRequest="38" VerticalOptions="End" BackgroundColor="#5D44B3" Stroke="Transparent" StrokeShape="RoundRectangle 6" />
