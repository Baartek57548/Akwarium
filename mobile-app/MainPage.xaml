                                <VerticalStackLayout Padding="16" Spacing="12">
                                    <Label Style="{StaticResource CardTitleStyle}" Text="Polaczenie BLE" />
                                    <Label Style="{StaticResource MutedTextStyle}" Text="{Binding BleConnectionHintText}" />
                                    <HorizontalStackLayout Spacing="8">
                                        <Button BackgroundColor="{StaticResource AccentCyan}" Command="{Binding ScanCommand}" CornerRadius="14" HeightRequest="42" Padding="16,0" Text="Skanuj" TextColor="#062133" />
                                        <Button BackgroundColor="{StaticResource GhostButtonBg}" BorderColor="{StaticResource BorderColor}" BorderWidth="1" Command="{Binding ConnectCommand}" CornerRadius="14" HeightRequest="42" Padding="16,0" Text="Polacz" TextColor="{StaticResource TextPrimary}" />
                                        <Button BackgroundColor="#35141E" Command="{Binding DisconnectCommand}" CornerRadius="14" HeightRequest="42" Padding="16,0" Text="Rozlacz" TextColor="{StaticResource AccentRed}" />
                                    </HorizontalStackLayout>
                                    <CollectionView HeightRequest="220" ItemsSource="{Binding DiscoveredDevices}" SelectedItem="{Binding SelectedDevice, Mode=TwoWay}" SelectionMode="Single">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="services:BleDeviceInfo">
                                                <Border Margin="0,0,0,8" Padding="10" BackgroundColor="#0C1727" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12">
                                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="4">
                                                        <Label FontFamily="OpenSansSemibold" FontSize="13" Text="{Binding DisplayName}" TextColor="{StaticResource TextPrimary}" />
                                                        <Label Grid.Column="1" FontSize="11" Text="{Binding SignalDescription}" TextColor="{StaticResource AccentCyan}" />
                                                        <Label Grid.Row="1" Grid.ColumnSpan="2" FontSize="11" Text="{Binding IdentifierSummary}" TextColor="{StaticResource TextMuted}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelCardStyle}">
                                <VerticalStackLayout Padding="16" Spacing="12">
                                    <Label Style="{StaticResource CardTitleStyle}" Text="Aktualizacja OTA" />
                                    <ProgressBar BackgroundColor="#14263B" HeightRequest="10" Progress="{Binding OtaProgress}" ProgressColor="{StaticResource AccentPurple}" />
                                    <Label FontFamily="OpenSansSemibold" FontSize="13" Text="{Binding OtaProgressPercentText}" TextColor="{StaticResource TextPrimary}" />
                                    <Label FontSize="12" LineBreakMode="WordWrap" Text="{Binding OtaStatusText}" TextColor="{StaticResource TextSecondary}" />
                                    <Label FontSize="11" LineBreakMode="WordWrap" Text="{Binding OtaProgressText}" TextColor="{StaticResource TextMuted}" />
                                    <Button BackgroundColor="{StaticResource GhostButtonBg}" BorderColor="{StaticResource BorderColor}" BorderWidth="1" Command="{Binding PickFirmwarePackageCommand}" CornerRadius="14" HeightRequest="42" Text="Wybierz .bin" TextColor="{StaticResource TextPrimary}" />
                                    <Button BackgroundColor="{StaticResource AccentPurple}" Command="{Binding StartBleOtaCommand}" CornerRadius="14" HeightRequest="42" Text="Wgraj OTA" TextColor="#1C1132" />
                                    <Button BackgroundColor="#35141E" Command="{Binding CancelBleOtaCommand}" CornerRadius="14" HeightRequest="42" Text="Anuluj transfer" TextColor="{StaticResource AccentRed}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource PanelCardStyle}">
                                <VerticalStackLayout Padding="16" Spacing="12">
                                    <Label Style="{StaticResource CardTitleStyle}" Text="Informacje systemowe" />
                                    <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                                        <Border Style="{StaticResource SubCardStyle}"><VerticalStackLayout Padding="10" Spacing="2"><Label Style="{StaticResource TinyMutedTextStyle}" Text="Firmware" /><Label FontFamily="OpenSansSemibold" FontSize="13" Text="{Binding CurrentFirmwareVersionText}" TextColor="{StaticResource TextPrimary}" /></VerticalStackLayout></Border>
                                        <Border Grid.Column="1" Style="{StaticResource SubCardStyle}"><VerticalStackLayout Padding="10" Spacing="2"><Label Style="{StaticResource TinyMutedTextStyle}" Text="Kompilacja" /><Label FontFamily="OpenSansSemibold" FontSize="13" Text="{Binding CurrentFirmwareBuildText}" TextColor="{StaticResource TextPrimary}" /></VerticalStackLayout></Border>
                                        <Border Grid.Column="2" Style="{StaticResource SubCardStyle}"><VerticalStackLayout Padding="10" Spacing="2"><Label Style="{StaticResource TinyMutedTextStyle}" Text="Partycje" /><Label FontFamily="OpenSansSemibold" FontSize="13" Text="{Binding CurrentFirmwarePartitionText}" TextColor="{StaticResource TextPrimary}" /></VerticalStackLayout></Border>
                                        <Border Grid.Column="3" Style="{StaticResource SubCardStyle}"><VerticalStackLayout Padding="10" Spacing="2"><Label Style="{StaticResource TinyMutedTextStyle}" Text="Siec" /><Label FontFamily="OpenSansSemibold" FontSize="13" Text="{Binding NetworkSummaryText}" TextColor="{StaticResource TextPrimary}" /></VerticalStackLayout></Border>
                                        <Border Grid.Row="1" Style="{StaticResource SubCardStyle}"><VerticalStackLayout Padding="10" Spacing="2"><Label Style="{StaticResource TinyMutedTextStyle}" Text="Adapter" /><Label FontFamily="OpenSansSemibold" FontSize="13" Text="{Binding AdapterStateText}" TextColor="{StaticResource TextPrimary}" /></VerticalStackLayout></Border>
                                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SubCardStyle}"><VerticalStackLayout Padding="10" Spacing="2"><Label Style="{StaticResource TinyMutedTextStyle}" Text="Kontroler" /><Label FontFamily="OpenSansSemibold" FontSize="13" Text="{Binding CurrentControllerName}" TextColor="{StaticResource TextPrimary}" /></VerticalStackLayout></Border>
                                        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource SubCardStyle}"><VerticalStackLayout Padding="10" Spacing="2"><Label Style="{StaticResource TinyMutedTextStyle}" Text="Kompatybilnosc" /><Label FontFamily="OpenSansSemibold" FontSize="13" Text="{Binding CurrentFirmwareCapabilityText}" TextColor="{StaticResource TextPrimary}" /></VerticalStackLayout></Border>
                                        <Border Grid.Row="1" Grid.Column="3" Style="{StaticResource SubCardStyle}"><VerticalStackLayout Padding="10" Spacing="2"><Label Style="{StaticResource TinyMutedTextStyle}" Text="Status" /><Label FontFamily="OpenSansSemibold" FontSize="13" LineBreakMode="TailTruncation" Text="{Binding LatestResultText}" TextColor="{StaticResource TextPrimary}" /></VerticalStackLayout></Border>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Border>
    </Grid>
</Grid>
</ContentPage>
