<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AquariumController.Mobile.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:behaviors="clr-namespace:AquariumController.Mobile.Behaviors"
    xmlns:services="clr-namespace:AquariumController.Mobile.Services"
    xmlns:viewModels="clr-namespace:AquariumController.Mobile.ViewModels"
    x:DataType="viewModels:MainViewModel"
    BackgroundColor="Transparent"
    NavigationPage.HasNavigationBar="False"
    Title="Akwarium">

    <ContentPage.Background>
        <LinearGradientBrush EndPoint="1,1">
            <GradientStop Color="#020617" Offset="0.0" />
            <GradientStop Color="#082032" Offset="0.42" />
            <GradientStop Color="#0A324C" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ContentPage.Resources>
        <Color x:Key="BgPanel">#0A1628</Color>
        <Color x:Key="BgCard">#0B1C30</Color>
        <Color x:Key="BorderColor">#1E3A5A</Color>
        <Color x:Key="TextMain">#F4FBFF</Color>
        <Color x:Key="TextMuted">#8FB0C7</Color>
        <Color x:Key="Accent">#5DEBFF</Color>
        <Color x:Key="AccentLime">#9BFFB0</Color>
        <Color x:Key="Success">#26D38C</Color>
        <Color x:Key="Danger">#FF6B8A</Color>
        <Color x:Key="OffState">#355069</Color>
        <Color x:Key="TerminalBg">#04101B</Color>
    </ContentPage.Resources>

    <Grid Padding="18" RowDefinitions="Auto,*" RowSpacing="18">
        <Border Grid.Row="0" BackgroundColor="{StaticResource BgPanel}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 16" StrokeThickness="1">
            <VerticalStackLayout Spacing="0">
                <Grid Padding="20" ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <VerticalStackLayout Spacing="6">
                        <Label FontFamily="OpenSansSemibold" FontSize="28" Text="Akwarium" TextColor="{StaticResource TextMain}" />
                        <Label FontSize="14" LineBreakMode="WordWrap" Text="{Binding BleConnectionHintText}" TextColor="{StaticResource TextMuted}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="6">
                        <Label FontFamily="OpenSansSemibold" FontSize="28" HorizontalTextAlignment="End" Text="{Binding CurrentTimeText}" TextColor="{StaticResource Accent}" />
                        <HorizontalStackLayout HorizontalOptions="End" Spacing="8">
                            <BoxView HeightRequest="8" WidthRequest="8" CornerRadius="4">
                                <BoxView.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" TargetType="BoxView" Value="True">
                                        <Setter Property="Color" Value="{StaticResource Success}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsConnected}" TargetType="BoxView" Value="False">
                                        <Setter Property="Color" Value="{StaticResource Danger}" />
                                    </DataTrigger>
                                </BoxView.Triggers>
                            </BoxView>
                            <Label FontFamily="OpenSansSemibold" FontSize="13" Text="{Binding ConnectionStatusBadgeText}">
                                <Label.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" TargetType="Label" Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource Success}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsConnected}" TargetType="Label" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource Danger}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </HorizontalStackLayout>
                        <Label FontSize="12" HorizontalTextAlignment="End" Text="{Binding AdapterStateText}" TextColor="{StaticResource TextMuted}" />
                    </VerticalStackLayout>
                </Grid>

                <Grid BackgroundColor="#16000000" ColumnDefinitions="*,*,*" ColumnSpacing="0">
                    <Button Grid.Column="0" BackgroundColor="Transparent" BorderWidth="0" Command="{Binding ShowDashboardTabCommand}" CornerRadius="0" FontFamily="OpenSansSemibold" FontSize="13" Padding="12,14" Text="DASHBOARD" TextColor="{StaticResource TextMuted}">
                        <Button.Triggers>
                            <DataTrigger Binding="{Binding IsDashboardTabSelected}" TargetType="Button" Value="True">
                                <Setter Property="BackgroundColor" Value="#143651" />
                                <Setter Property="TextColor" Value="{StaticResource Accent}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <Button Grid.Column="1" BackgroundColor="Transparent" BorderWidth="0" Command="{Binding ShowLogsTabCommand}" CornerRadius="0" FontFamily="OpenSansSemibold" FontSize="13" Padding="12,14" Text="LOGI" TextColor="{StaticResource TextMuted}">
                        <Button.Triggers>
                            <DataTrigger Binding="{Binding IsLogsTabSelected}" TargetType="Button" Value="True">
                                <Setter Property="BackgroundColor" Value="#143651" />
                                <Setter Property="TextColor" Value="{StaticResource Accent}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <Button Grid.Column="2" BackgroundColor="Transparent" BorderWidth="0" Command="{Binding ShowSystemTabCommand}" CornerRadius="0" FontFamily="OpenSansSemibold" FontSize="13" Padding="12,14" Text="SYSTEM / OTA" TextColor="{StaticResource TextMuted}">
                        <Button.Triggers>
                            <DataTrigger Binding="{Binding IsSystemTabSelected}" TargetType="Button" Value="True">
                                <Setter Property="BackgroundColor" Value="#143651" />
                                <Setter Property="TextColor" Value="{StaticResource Accent}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <Grid Grid.Row="1">
            <ScrollView IsVisible="{Binding IsDashboardTabSelected}">
                <ScrollView.Behaviors>
                    <behaviors:EntranceAnimationBehavior />
                </ScrollView.Behaviors>
                <VerticalStackLayout Spacing="18">
                    <Border BackgroundColor="#10263A" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                        <Grid Padding="18" ColumnDefinitions="*,Auto" ColumnSpacing="16">
                            <VerticalStackLayout Spacing="6">
                                <Label FontFamily="OpenSansSemibold" FontSize="22" Text="Panel sterowania akwarium" TextColor="{StaticResource TextMain}" />
                                <Label FontSize="14" LineBreakMode="WordWrap" Text="{Binding StatusMessage}" TextColor="{StaticResource TextMuted}" />
                                <Label FontSize="13" Text="{Binding LastStatusUpdateText}" TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                                <Button BackgroundColor="{StaticResource Accent}" Command="{Binding RefreshStatusCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Odswiez" TextColor="White" />
                                <Button BackgroundColor="{StaticResource BgCard}" BorderColor="{StaticResource BorderColor}" BorderWidth="1" Command="{Binding ShowSystemTabCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Panel BLE" TextColor="{StaticResource TextMain}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="18">
                        <Border BackgroundColor="{StaticResource BgPanel}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 14" StrokeThickness="1">
                            <VerticalStackLayout Padding="18" Spacing="10">
                                <Label FontFamily="OpenSansSemibold" FontSize="13" Text="CZUJNIKI" TextColor="{StaticResource TextMuted}" />
                                <Label FontSize="13" Text="Temperatura" TextColor="{StaticResource TextMuted}" />
                                <Label FontFamily="OpenSansSemibold" FontSize="28" Text="{Binding CurrentStatus.TemperatureText}" TextColor="{StaticResource TextMain}" />
                                <HorizontalStackLayout Spacing="8">
                                    <Label FontSize="13" Text="Minimum:" TextColor="{StaticResource TextMuted}" />
                                    <Label FontFamily="OpenSansSemibold" FontSize="13" Text="{Binding MinTemperatureText}" TextColor="{StaticResource TextMain}" />
                                    <Label FontSize="13" Text="{Binding MinTemperatureTimeText}" TextColor="{StaticResource TextMuted}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1" BackgroundColor="{StaticResource BgPanel}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 14" StrokeThickness="1">
                            <VerticalStackLayout Padding="18" Spacing="10">
                                <Label FontFamily="OpenSansSemibold" FontSize="13" Text="ZASILANIE" TextColor="{StaticResource TextMuted}" />
                                <Label FontSize="13" Text="Bateria" TextColor="{StaticResource TextMuted}" />
                                <Label FontFamily="OpenSansSemibold" FontSize="28" Text="{Binding CurrentStatus.BatteryPercent, StringFormat='{}{0}%'}" TextColor="{StaticResource TextMain}" />
                                <ProgressBar BackgroundColor="{StaticResource OffState}" HeightRequest="10" Progress="{Binding BatteryProgress}" ProgressColor="{Binding BatteryFillColor}" />
                                <Label FontFamily="OpenSansSemibold" FontSize="13" Text="{Binding CurrentStatus.BatteryVoltageText}" TextColor="{StaticResource TextMain}" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="2" BackgroundColor="{StaticResource BgPanel}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 14" StrokeThickness="1">
                            <VerticalStackLayout Padding="18" Spacing="10">
                                <Label FontFamily="OpenSansSemibold" FontSize="13" Text="KONTROLER" TextColor="{StaticResource TextMuted}" />
                                <Label FontSize="13" Text="Polaczenie" TextColor="{StaticResource TextMuted}" />
                                <Label FontFamily="OpenSansSemibold" FontSize="22" Text="{Binding ConnectionStateText}" TextColor="{StaticResource TextMain}" />
                                <Label FontSize="13" Text="{Binding NetworkSummaryText}" TextColor="{StaticResource TextMuted}" />
                                <Label FontSize="13" Text="{Binding CurrentStatus.IpAddress}" TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Border BackgroundColor="{StaticResource BgPanel}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                        <VerticalStackLayout Padding="18" Spacing="16">
                            <Label FontFamily="OpenSansSemibold" FontSize="13" Text="URZADZENIA I HARMONOGRAMY" TextColor="{StaticResource TextMuted}" />
                            <Label FontSize="13" LineBreakMode="WordWrap" Text="Formularz korzysta z jawnych trybow pracy i pickerow zgodnych z profilem walidacji z firmware. Zapis jest blokowany dopoki konfiguracja nie bedzie poprawna." TextColor="{StaticResource TextMuted}" />

                            <Border BackgroundColor="#081725" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                                <VerticalStackLayout Padding="16" Spacing="12">
                                    <Grid ColumnDefinitions="*,180" ColumnSpacing="12">
                                        <VerticalStackLayout Spacing="4">
                                            <Label FontFamily="OpenSansSemibold" FontSize="16" Text="Oswietlenie" TextColor="{StaticResource TextMain}" />
                                            <Label FontSize="13" Text="{Binding CurrentStatus.LightText}" TextColor="{StaticResource TextMuted}" />
                                        </VerticalStackLayout>
                                        <Picker Grid.Column="1" BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding ScheduleModes}" SelectedItem="{Binding SelectedLightMode}" TextColor="{StaticResource TextMain}" />
                                    </Grid>
                                    <Label FontSize="12" Text="{Binding LightScheduleHintText}" TextColor="{StaticResource TextMuted}" />
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" IsEnabled="{Binding IsLightScheduleEditable}">
                                        <VerticalStackLayout Spacing="6">
                                            <Label FontSize="12" Text="Start" TextColor="{StaticResource TextMuted}" />
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <Picker BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding HourOptions}" SelectedItem="{Binding SelectedDayStartHour}" TextColor="{StaticResource TextMain}" />
                                                <Picker Grid.Column="1" BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding MinuteOptions}" SelectedItem="{Binding SelectedDayStartMinute}" TextColor="{StaticResource TextMain}" />
                                            </Grid>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                                            <Label FontSize="12" Text="Stop" TextColor="{StaticResource TextMuted}" />
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <Picker BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding HourOptions}" SelectedItem="{Binding SelectedDayEndHour}" TextColor="{StaticResource TextMain}" />
                                                <Picker Grid.Column="1" BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding MinuteOptions}" SelectedItem="{Binding SelectedDayEndMinute}" TextColor="{StaticResource TextMain}" />
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Grid>
                                    <Label FontSize="12" IsVisible="{Binding HasLightScheduleError}" Text="{Binding LightScheduleErrorText}" TextColor="{StaticResource Danger}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border BackgroundColor="#081725" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                                <VerticalStackLayout Padding="16" Spacing="12">
                                    <Grid ColumnDefinitions="*,180" ColumnSpacing="12">
                                        <VerticalStackLayout Spacing="4">
                                            <Label FontFamily="OpenSansSemibold" FontSize="16" Text="Filtr" TextColor="{StaticResource TextMain}" />
                                            <Label FontSize="13" Text="{Binding CurrentStatus.FilterText}" TextColor="{StaticResource TextMuted}" />
                                        </VerticalStackLayout>
                                        <Picker Grid.Column="1" BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding ScheduleModes}" SelectedItem="{Binding SelectedFilterMode}" TextColor="{StaticResource TextMain}" />
                                    </Grid>
                                    <Label FontSize="12" Text="{Binding FilterScheduleHintText}" TextColor="{StaticResource TextMuted}" />
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" IsEnabled="{Binding IsFilterScheduleEditable}">
                                        <VerticalStackLayout Spacing="6">
                                            <Label FontSize="12" Text="Start" TextColor="{StaticResource TextMuted}" />
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <Picker BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding HourOptions}" SelectedItem="{Binding SelectedFilterOnHour}" TextColor="{StaticResource TextMain}" />
                                                <Picker Grid.Column="1" BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding MinuteOptions}" SelectedItem="{Binding SelectedFilterOnMinute}" TextColor="{StaticResource TextMain}" />
                                            </Grid>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                                            <Label FontSize="12" Text="Stop" TextColor="{StaticResource TextMuted}" />
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <Picker BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding HourOptions}" SelectedItem="{Binding SelectedFilterOffHour}" TextColor="{StaticResource TextMain}" />
                                                <Picker Grid.Column="1" BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding MinuteOptions}" SelectedItem="{Binding SelectedFilterOffMinute}" TextColor="{StaticResource TextMain}" />
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Grid>
                                    <Label FontSize="12" IsVisible="{Binding HasFilterScheduleError}" Text="{Binding FilterScheduleErrorText}" TextColor="{StaticResource Danger}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border BackgroundColor="#081725" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                                <VerticalStackLayout Padding="16" Spacing="12">
                                    <Grid ColumnDefinitions="*,180" ColumnSpacing="12">
                                        <VerticalStackLayout Spacing="4">
                                            <Label FontFamily="OpenSansSemibold" FontSize="16" Text="Napowietrzanie" TextColor="{StaticResource TextMain}" />
                                            <Label FontSize="13" Text="{Binding ServoPercentText}" TextColor="{StaticResource AccentLime}" />
                                            <Label FontSize="12" Text="{Binding ServoModeText}" TextColor="{StaticResource TextMuted}" />
                                        </VerticalStackLayout>
                                        <Picker Grid.Column="1" BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding ScheduleModes}" SelectedItem="{Binding SelectedAerationMode}" TextColor="{StaticResource TextMain}" />
                                    </Grid>
                                    <Label FontSize="12" Text="{Binding AerationScheduleHintText}" TextColor="{StaticResource TextMuted}" />
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" IsEnabled="{Binding IsAerationScheduleEditable}">
                                        <VerticalStackLayout Spacing="6">
                                            <Label FontSize="12" Text="Start" TextColor="{StaticResource TextMuted}" />
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <Picker BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding HourOptions}" SelectedItem="{Binding SelectedAerationOnHour}" TextColor="{StaticResource TextMain}" />
                                                <Picker Grid.Column="1" BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding MinuteOptions}" SelectedItem="{Binding SelectedAerationOnMinute}" TextColor="{StaticResource TextMain}" />
                                            </Grid>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                                            <Label FontSize="12" Text="Stop" TextColor="{StaticResource TextMuted}" />
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <Picker BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding HourOptions}" SelectedItem="{Binding SelectedAerationOffHour}" TextColor="{StaticResource TextMain}" />
                                                <Picker Grid.Column="1" BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding MinuteOptions}" SelectedItem="{Binding SelectedAerationOffMinute}" TextColor="{StaticResource TextMain}" />
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Grid>
                                    <Slider Maximum="100" Minimum="0" MaximumTrackColor="{StaticResource OffState}" MinimumTrackColor="{StaticResource Accent}" ThumbColor="{StaticResource Accent}" Value="{Binding ServoPercent}" />
                                    <HorizontalStackLayout Spacing="8">
                                        <Button BackgroundColor="{StaticResource BgCard}" BorderColor="{StaticResource BorderColor}" BorderWidth="1" Command="{Binding ApplyServoSliderCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Zastosuj" TextColor="{StaticResource TextMain}" />
                                        <Button BackgroundColor="{StaticResource BgCard}" BorderColor="{StaticResource BorderColor}" BorderWidth="1" Command="{Binding OpenServoCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Otworz" TextColor="{StaticResource TextMain}" />
                                        <Button BackgroundColor="{StaticResource BgCard}" BorderColor="{StaticResource BorderColor}" BorderWidth="1" Command="{Binding CloseServoCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Zamknij" TextColor="{StaticResource TextMain}" />
                                        <Button BackgroundColor="{StaticResource BgCard}" BorderColor="{StaticResource BorderColor}" BorderWidth="1" Command="{Binding ClearServoOverrideCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Auto" TextColor="{StaticResource TextMain}" />
                                    </HorizontalStackLayout>
                                    <Label FontSize="12" IsVisible="{Binding HasAerationScheduleError}" Text="{Binding AerationScheduleErrorText}" TextColor="{StaticResource Danger}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border BackgroundColor="#081725" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                                <VerticalStackLayout Padding="16" Spacing="12">
                                    <Grid ColumnDefinitions="*,180" ColumnSpacing="12">
                                        <VerticalStackLayout Spacing="4">
                                            <Label FontFamily="OpenSansSemibold" FontSize="16" Text="Termostat" TextColor="{StaticResource TextMain}" />
                                            <Label FontSize="13" Text="{Binding CurrentStatus.HeaterText}" TextColor="{StaticResource TextMuted}" />
                                        </VerticalStackLayout>
                                        <Picker Grid.Column="1" BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding HeaterTargetOptions}" SelectedItem="{Binding SelectedHeaterTarget}" TextColor="{StaticResource TextMain}" />
                                    </Grid>
                                    <Label FontSize="12" Text="Maks. temperatura oznacza prog odciecia grzalki. Powrot nastapi dopiero po spadku o histereze." TextColor="{StaticResource TextMuted}" />
                                    <Grid ColumnDefinitions="Auto,180" ColumnSpacing="12">
                                        <Label FontSize="13" Text="Histereza" TextColor="{StaticResource TextMuted}" VerticalTextAlignment="Center" />
                                        <Picker Grid.Column="1" BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding HysteresisOptions}" SelectedItem="{Binding SelectedHysteresisOption}" TextColor="{StaticResource TextMain}" />
                                    </Grid>
                                    <Label FontSize="12" IsVisible="{Binding HasHeaterScheduleError}" Text="{Binding HeaterScheduleErrorText}" TextColor="{StaticResource Danger}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border BackgroundColor="#081725" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                                <VerticalStackLayout Padding="16" Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <VerticalStackLayout Spacing="4">
                                            <Label FontFamily="OpenSansSemibold" FontSize="16" Text="Karmnik" TextColor="{StaticResource TextMain}" />
                                            <Label FontSize="12" Text="Godzina karmienia jest ograniczona do tego samego kroku minut co reszta harmonogramow." TextColor="{StaticResource TextMuted}" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="1" BackgroundColor="{StaticResource Accent}" Command="{Binding FeedNowCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Karm teraz" TextColor="White" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*,200" ColumnSpacing="12">
                                        <VerticalStackLayout Spacing="6">
                                            <Label FontSize="12" Text="Godzina" TextColor="{StaticResource TextMuted}" />
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <Picker BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding HourOptions}" SelectedItem="{Binding SelectedFeedHour}" TextColor="{StaticResource TextMain}" />
                                                <Picker Grid.Column="1" BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding MinuteOptions}" SelectedItem="{Binding SelectedFeedMinute}" TextColor="{StaticResource TextMain}" />
                                            </Grid>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1" Grid.ColumnSpan="2" Spacing="6">
                                            <Label FontSize="12" Text="Tryb" TextColor="{StaticResource TextMuted}" />
                                            <Picker BackgroundColor="{StaticResource BgCard}" ItemDisplayBinding="{Binding Label}" ItemsSource="{Binding FeedModes}" SelectedItem="{Binding SelectedFeedMode}" TextColor="{StaticResource TextMain}" />
                                        </VerticalStackLayout>
                                    </Grid>
                                    <Label FontSize="12" IsVisible="{Binding HasFeedScheduleError}" Text="{Binding FeedScheduleErrorText}" TextColor="{StaticResource Danger}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border BackgroundColor="{StaticResource BgCard}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                                <VerticalStackLayout Padding="14" Spacing="10">
                                    <Label FontSize="13" Text="Ostatnia odpowiedz sterownika" TextColor="{StaticResource TextMuted}" />
                                    <Label FontFamily="OpenSansSemibold" LineBreakMode="WordWrap" Text="{Binding LatestResultText}" TextColor="{StaticResource TextMain}" />
                                    <Label FontSize="12" IsVisible="{Binding HasScheduleValidationSummary}" LineBreakMode="WordWrap" Text="{Binding ScheduleValidationSummary}" TextColor="{StaticResource Danger}" />
                                    <HorizontalStackLayout Spacing="10">
                                        <Button BackgroundColor="{StaticResource BgCard}" BorderColor="{StaticResource BorderColor}" BorderWidth="1" Command="{Binding RefreshStatusCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Odswiez" TextColor="{StaticResource TextMain}" />
                                        <Button BackgroundColor="{StaticResource Accent}" Command="{Binding SaveSchedulesCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" IsEnabled="{Binding CanSaveSchedules}" Padding="16,0" Text="Zapisz harmonogramy" TextColor="White" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>

            <Grid IsVisible="{Binding IsLogsTabSelected}">
                <Grid.Behaviors>
                    <behaviors:EntranceAnimationBehavior />
                </Grid.Behaviors>
                <Border BackgroundColor="{StaticResource BgPanel}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                    <Grid RowDefinitions="Auto,*" RowSpacing="0">
                        <Grid Padding="18" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label FontFamily="OpenSansSemibold" FontSize="13" Text="LOGI SYSTEMOWE" TextColor="{StaticResource TextMuted}" />
                                <Label FontSize="13" LineBreakMode="TailTruncation" Text="{Binding LatestResultText}" TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>

                            <HorizontalStackLayout Grid.Column="1" Spacing="8">
                                <Button BackgroundColor="{StaticResource BgCard}" BorderColor="{StaticResource BorderColor}" BorderWidth="1" Command="{Binding ShowSystemLogsCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Systemowe" TextColor="{StaticResource TextMain}" />
                                <Button BackgroundColor="{StaticResource BgCard}" BorderColor="{StaticResource BorderColor}" BorderWidth="1" Command="{Binding ShowCriticalLogsCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Krytyczne" TextColor="{StaticResource TextMain}" />
                                <Button BackgroundColor="{StaticResource BgCard}" BorderColor="{StaticResource BorderColor}" BorderWidth="1" Command="{Binding ClearLogsViewCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Wyczysc widok" TextColor="{StaticResource TextMain}" />
                                <Button BackgroundColor="{StaticResource Danger}" Command="{Binding ClearCriticalLogsCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Usun krytyczne" TextColor="White" />
                            </HorizontalStackLayout>
                        </Grid>

                        <Border Grid.Row="1" Margin="18,0,18,18" BackgroundColor="{StaticResource TerminalBg}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                            <CollectionView ItemsSource="{Binding VisibleLogs}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:ActivityLogEntry">
                                        <Label Padding="16,8" FontSize="13" Text="{Binding FormattedText}" TextColor="{Binding ColorHex}" />
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                                <CollectionView.EmptyView>
                                    <Label Padding="18" Text="Brak logow do wyswietlenia." TextColor="{StaticResource TextMuted}" />
                                </CollectionView.EmptyView>
                            </CollectionView>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <ScrollView IsVisible="{Binding IsSystemTabSelected}">
                <ScrollView.Behaviors>
                    <behaviors:EntranceAnimationBehavior />
                </ScrollView.Behaviors>
                <VerticalStackLayout Spacing="18">
                    <Border BackgroundColor="{StaticResource BgPanel}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                        <VerticalStackLayout Padding="18" Spacing="16">
                            <VerticalStackLayout Spacing="4">
                                <Label FontFamily="OpenSansSemibold" FontSize="13" Text="POLACZENIE BLE" TextColor="{StaticResource TextMuted}" />
                                <Label FontSize="13" Text="{Binding BleConnectionHintText}" TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>

                            <HorizontalStackLayout Spacing="10">
                                <Button BackgroundColor="{StaticResource Accent}" Command="{Binding ScanCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Skanuj" TextColor="White" />
                                <Button BackgroundColor="{StaticResource BgCard}" BorderColor="{StaticResource BorderColor}" BorderWidth="1" Command="{Binding ConnectCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Polacz" TextColor="{StaticResource TextMain}" />
                                <Button BackgroundColor="{StaticResource Danger}" Command="{Binding DisconnectCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Rozlacz" TextColor="White" />
                            </HorizontalStackLayout>

                            <Grid ColumnDefinitions="1.05*,1.45*" ColumnSpacing="18">
                                <Border BackgroundColor="{StaticResource BgCard}" Padding="14" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                                    <VerticalStackLayout Spacing="6">
                                        <Label FontSize="13" Text="Wybrane urzadzenie" TextColor="{StaticResource TextMuted}" />
                                        <Label FontFamily="OpenSansSemibold" Text="{Binding SelectedDeviceSummary}" TextColor="{StaticResource TextMain}" />
                                        <Label FontSize="13" Text="{Binding ConnectionStateText}" TextColor="{StaticResource TextMuted}" />
                                    </VerticalStackLayout>
                                </Border>

                                <CollectionView Grid.Column="1" HeightRequest="280" ItemsSource="{Binding DiscoveredDevices}" SelectedItem="{Binding SelectedDevice, Mode=TwoWay}" SelectionMode="Single">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="services:BleDeviceInfo">
                                            <Border Margin="0,0,0,12" Padding="14" BackgroundColor="{StaticResource BgCard}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="6">
                                                    <Label FontFamily="OpenSansSemibold" FontSize="15" Text="{Binding DisplayName}" TextColor="{StaticResource TextMain}" />
                                                    <Label Grid.Column="1" FontSize="12" Text="{Binding SignalDescription}" TextColor="{StaticResource Accent}" />
                                                    <Label Grid.Row="1" Grid.ColumnSpan="2" FontSize="12" Text="{Binding IdentifierSummary}" TextColor="{StaticResource TextMuted}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                    <CollectionView.EmptyView>
                                        <Label Padding="18" Text="Brak wykrytych urzadzen BLE." TextColor="{StaticResource TextMuted}" />
                                    </CollectionView.EmptyView>
                                </CollectionView>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="{StaticResource BgPanel}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                        <VerticalStackLayout Padding="18" Spacing="16">
                            <Label FontFamily="OpenSansSemibold" FontSize="13" Text="SYSTEM / OTA" TextColor="{StaticResource TextMuted}" />

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                                <Border BackgroundColor="{StaticResource BgCard}" Padding="14" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                                    <VerticalStackLayout Spacing="6">
                                        <Label FontSize="13" Text="Adres IP" TextColor="{StaticResource TextMuted}" />
                                        <Label FontFamily="OpenSansSemibold" FontSize="20" Text="{Binding CurrentStatus.IpAddress}" TextColor="{StaticResource TextMain}" />
                                        <Label FontSize="13" Text="{Binding NetworkSummaryText}" TextColor="{StaticResource TextMuted}" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Column="1" BackgroundColor="{StaticResource BgCard}" Padding="14" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                                    <VerticalStackLayout Spacing="6">
                                        <Label FontSize="13" Text="BLE / Kontroler" TextColor="{StaticResource TextMuted}" />
                                        <Label FontFamily="OpenSansSemibold" FontSize="20" Text="{Binding CurrentControllerName}" TextColor="{StaticResource TextMain}" />
                                        <Label FontSize="13" Text="{Binding CurrentDeviceInfo.OtaTransportText}" TextColor="{StaticResource Accent}" />
                                        <Label FontSize="13" Text="{Binding ConnectionClientsText}" TextColor="{StaticResource TextMuted}" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <Border Padding="16" BackgroundColor="{StaticResource BgCard}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                                <VerticalStackLayout Spacing="8">
                                    <Label FontSize="13" Text="Kontrakt BLE" TextColor="{StaticResource TextMuted}" />
                                    <Label FontFamily="OpenSansSemibold" FontSize="13" Text="Usluga: 4fafc201-1fb5-459e-8bcc-c5c9c331914b" TextColor="{StaticResource TextMain}" />
                                    <Label FontSize="13" LineBreakMode="WordWrap" Text="Kontroler reklamuje sie jako Akwarium_BLE. Po sparowaniu panel odczyta status, ustawienia i profil walidacji bez zgadywania zakresow." TextColor="{StaticResource TextMuted}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Padding="16" BackgroundColor="#102637" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                                <VerticalStackLayout Spacing="8">
                                    <Label FontSize="13" Text="Informacja OTA" TextColor="{StaticResource TextMuted}" />
                                    <Label FontSize="14" LineBreakMode="WordWrap" Text="{Binding OtaInfoText}" TextColor="{StaticResource TextMain}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Padding="16" BackgroundColor="{StaticResource BgCard}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                                <VerticalStackLayout Spacing="12">
                                    <Label FontSize="13" Text="Zainstalowane oprogramowanie" TextColor="{StaticResource TextMuted}" />
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                                        <Label FontSize="13" Text="Wersja" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Column="1" FontFamily="OpenSansSemibold" FontSize="16" Text="{Binding CurrentFirmwareVersionText}" TextColor="{StaticResource TextMain}" />
                                        <Label Grid.Row="1" FontSize="13" Text="Kompilacja" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Row="1" Grid.Column="1" FontSize="13" Text="{Binding CurrentFirmwareBuildText}" TextColor="{StaticResource TextMain}" />
                                        <Label Grid.Row="2" FontSize="13" Text="Partycje" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Row="2" Grid.Column="1" FontSize="13" Text="{Binding CurrentFirmwarePartitionText}" TextColor="{StaticResource TextMain}" />
                                        <Label Grid.Row="3" FontSize="13" Text="Mozliwosci" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Row="3" Grid.Column="1" FontSize="13" Text="{Binding CurrentFirmwareCapabilityText}" TextColor="{StaticResource TextMain}" />
                                        <Label Grid.Row="4" FontSize="13" Text="ESP-IDF" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Row="4" Grid.Column="1" FontSize="13" Text="{Binding CurrentDeviceInfo.IdfVersion}" TextColor="{StaticResource TextMain}" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <Border Padding="16" BackgroundColor="{StaticResource BgCard}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                                <VerticalStackLayout Spacing="12">
                                    <Label FontSize="13" Text="Wybrany pakiet" TextColor="{StaticResource TextMuted}" />
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                                        <Label FontSize="13" Text="Plik" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Column="1" FontFamily="OpenSansSemibold" FontSize="14" Text="{Binding SelectedFirmwarePackage.FileName}" TextColor="{StaticResource TextMain}" />
                                        <Label Grid.Row="1" FontSize="13" Text="Wersja" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Row="1" Grid.Column="1" FontSize="13" Text="{Binding SelectedFirmwareVersionText}" TextColor="{StaticResource TextMain}" />
                                        <Label Grid.Row="2" FontSize="13" Text="Kompilacja" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Row="2" Grid.Column="1" FontSize="13" Text="{Binding SelectedFirmwareBuildText}" TextColor="{StaticResource TextMain}" />
                                        <Label Grid.Row="3" FontSize="13" Text="Rozmiar" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Row="3" Grid.Column="1" FontSize="13" Text="{Binding SelectedFirmwarePackage.FileSizeText}" TextColor="{StaticResource TextMain}" />
                                        <Label Grid.Row="4" FontSize="13" Text="Walidacja" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Row="4" Grid.Column="1" FontSize="13" LineBreakMode="WordWrap" Text="{Binding SelectedFirmwareValidationText}" TextColor="{StaticResource TextMain}" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <Border Padding="16" BackgroundColor="#102637" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 12" StrokeThickness="1">
                                <VerticalStackLayout Spacing="12">
                                    <Label FontSize="13" Text="Aktualizacja OTA przez BLE" TextColor="{StaticResource TextMuted}" />
                                    <ProgressBar BackgroundColor="{StaticResource OffState}" HeightRequest="10" Progress="{Binding OtaProgress}" ProgressColor="{StaticResource Accent}" />
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                                        <Label FontSize="13" Text="Postep" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Column="1" FontFamily="OpenSansSemibold" FontSize="13" Text="{Binding OtaProgressPercentText}" TextColor="{StaticResource TextMain}" />
                                        <Label Grid.Row="1" FontSize="13" Text="Status" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Row="1" Grid.Column="1" FontSize="13" LineBreakMode="WordWrap" Text="{Binding OtaStatusText}" TextColor="{StaticResource TextMain}" />
                                    </Grid>
                                    <Label FontSize="13" LineBreakMode="WordWrap" Text="{Binding OtaProgressText}" TextColor="{StaticResource TextMuted}" />
                                    <HorizontalStackLayout Spacing="10">
                                        <Button BackgroundColor="{StaticResource BgCard}" BorderColor="{StaticResource BorderColor}" BorderWidth="1" Command="{Binding PickFirmwarePackageCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Wybierz .bin" TextColor="{StaticResource TextMain}" />
                                        <Button BackgroundColor="{StaticResource Accent}" Command="{Binding StartBleOtaCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Wgraj przez BLE" TextColor="White" />
                                        <Button BackgroundColor="{StaticResource Danger}" Command="{Binding CancelBleOtaCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Anuluj" TextColor="White" />
                                        <Button BackgroundColor="{StaticResource BgCard}" BorderColor="{StaticResource BorderColor}" BorderWidth="1" Command="{Binding RefreshStatusCommand}" CornerRadius="12" FontFamily="OpenSansSemibold" FontSize="13" HeightRequest="42" Padding="16,0" Text="Odswiez" TextColor="{StaticResource TextMain}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
